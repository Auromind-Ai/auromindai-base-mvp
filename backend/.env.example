# ========== Core / Pydantic Settings ==========
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
SECRET_KEY=placeholder_for_jwt_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
OWNER_SECRET_KEY=placeholder_for_owner_secret_key
ENCRYPTION_KEY=placeholder_for_fernet_encryption_key
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ========== Database & Queue ==========
DATABASE_URL=postgresql+psycopg2://postgres:postgres_password@localhost:5432/postgres_db
REDIS_URL=redis://localhost:6379/0

# ========== AI API Keys ==========
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here
HF_HOME=/models/huggingface
TRANSFORMERS_CACHE=/models/huggingface
HF_HUB_ENABLE_HF_TRANSFER=1

# ========== Google OAuth ==========
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ========== Meta / Instagram Integration ==========
META_VERIFY_TOKEN=your_meta_verify_token_here
META_SYSTEM_USER_TOKEN=your_meta_system_user_token_here
IG_APP_ID=your_instagram_app_id_here
IG_APP_SECRET=your_instagram_app_secret_here
IG_REDIRECT_URI=http://localhost:3000/instagram/callback

# ========== Twilio Integration ==========
TWILIO_STATUS_CALLBACK_URL=your_twilio_status_callback_url_here

# ========== Razorpay Payments ==========
RAZORPAY_KEY=your_razorpay_key_here
RAZORPAY_SECRET=your_razorpay_secret_here
RAZORPAY_PRO_PLAN_ID=your_razorpay_pro_plan_id_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ========== Supabase Storage ==========
STORAGE_PROVIDER=SUPABASE
SUPABASE_BUCKET=media
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ========== SMTP Email Settings ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email_address_here
SMTP_PASS=your_email_app_password_here
FROM_EMAIL=your_email_address_here
