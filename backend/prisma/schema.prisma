generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  full_name       String
  password_hash   String?
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  
  // Relations
  workspace_members WorkspaceMember[]
  learning_events   LearningEvent[]
  followups         Followup[]
  conversations     Conversation[]
  promises          Promise[]

  @@map("users")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  created_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  members         WorkspaceMember[]
  learning_events LearningEvent[]
  followups       Followup[]
  ai_actions      AIAction[]
  brain_entries   Brain[]
  conversations   Conversation[]
  promises        Promise[]

  @@map("workspaces")
}

model WorkspaceMember {
  id           String   @id @default(uuid())
  user_id      String
  workspace_id String
  role         String
  created_at   DateTime @default(now())

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("workspace_members")
}

model LearningEvent {
  id                      String   @id @default(uuid())
  workspace_id            String
  user_message            String   @db.Text
  ai_response             String   @db.Text
  conversation_id         String?
  ai_action_id            String?
  mcp_verdict             String?
  mcp_confidence          Float?
  feedback_type           String   @default("no_feedback")
  feedback_comment        String?  @db.Text
  feedback_timestamp      DateTime?
  execution_success       Boolean?
  user_satisfaction_score Float?
  pattern_tags            Json?
  used_in_training        Boolean  @default(false)
  promoted_to_rule        Boolean  @default(false)
  created_at              DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("ai_learning_events")
}

model Followup {
  id               String    @id @default(uuid())
  conversation_id  String?
  scheduled_at     DateTime
  status           String    @default("pending")
  message_content  String?   @db.Text
  followup_count   Int       @default(0)
  mcp_decision     String?
  mcp_reason       String?   @db.Text
  created_at       DateTime  @default(now())
  executed_at      DateTime?

  workspace_id     String?
  user_id          String?

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [user_id], references: [id])

  @@map("followups")
}

model AIAction {
  id               String   @id @default(uuid())
  workspace_id     String
  action_type      String
  intent           String?  @db.Text
  intent_raw       String?  @db.Text
  confidence       Float?
  mcp_decision     String?
  mcp_reason       String?  @db.Text
  rule_results     Json?
  context_refs     Json?
  execution_status String   @default("pending")
  human_override   Boolean  @default(false)
  action_metadata  Json?
  created_at       DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("ai_actions")
}

model Brain {
  id           String   @id @default(uuid())
  workspace_id String
  title        String
  content      String   @db.Text
  source_type  String?
  source_url   String?  @db.Text
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("brain")
}

model Conversation {
  id           String   @id @default(uuid())
  workspace_id String?
  user_id      String?
  title        String?
  
  // Fields from Python model
  channel      String   @default("WEB") // Enum in Python, String here for simplicity
  external_id  String?
  contact_name String?
  status       String   @default("OPEN")
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [user_id], references: [id])
  messages  Message[]

  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  conversation_id String
  
  // Fields from Python model
  role            String? // Keeping role for compatibility if needed
  sender_type     String  @default("USER") // USER, AI, AGENT, SYSTEM
  content         String  @db.Text
  timestamp       DateTime @default(now())
  is_read         Boolean  @default(false)
  metadata_json   String?  @db.Text

  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Promise {
  id           String   @id @default(uuid())
  workspace_id String
  user_id      String?
  description  String   @db.Text
  due_date     DateTime?
  status       String   @default("pending")
  source       String   @default("manual")
  ai_action_id String?
  created_at   DateTime @default(now())
  resolved_at  DateTime?

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [user_id], references: [id])

  @@map("promises")
}
