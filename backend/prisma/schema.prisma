model AILearningEvent {
  id                      String    @id @default(uuid()) @db.Uuid
  workspace_id            String?   @db.Uuid
  user_message            String    @db.Text
  ai_response             String    @db.Text
  conversation_id         String?   @db.Uuid
  ai_action_id            String?   @db.Uuid
  mcp_verdict             String?   @db.VarChar(50)
  mcp_confidence          Float?
  feedback_type           FeedbackType?
  feedback_comment        String?   @db.Text
  feedback_timestamp      DateTime? @db.Timestamptz(6)
  execution_success       Boolean?
  user_satisfaction_score Float?
  pattern_tags            Json?
  used_in_training        Boolean?
  promoted_to_rule        Boolean?
  created_at              DateTime  @default(now()) @db.Timestamptz(6)

  workspace     Workspace?     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  conversation  Conversation?  @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  ai_action     AIAction?      @relation(fields: [ai_action_id], references: [id], onDelete: SetNull)

  @@map("ai_learning_events")
}

model EmailState {
  workspace_id   String   @id @db.Uuid
  last_email_id  String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("email_states")
}

model ConversationThread {
  id                String   @id @default(uuid())
  workspace_id      String   @db.Uuid
  thread_id         String

  sender_email      String?
  subject           String?

  conversation_summary String?
  last_category     String?
  last_priority     String?

  status            String   @default("open")  // open / closed / waiting

  last_message_id   String?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([workspace_id])
  @@index([thread_id])
  @@unique([workspace_id, thread_id])
  @@map("conversation_threads")
}

model MCPDecision {
  id                        String   @id @default(uuid())
  workspace_id              String   @db.Uuid

  message_id                String
  thread_id                 String?

  category                  String?
  priority                  String?
  confidence                Float?

  entities_json             Json?
  summary                   String?
  suggested_reply           String?

  requires_user_permission  Boolean  @default(false)
  user_action               String?  // pending / approved / rejected

  executed_actions_json     Json?

  created_at                DateTime @default(now())

  @@index([workspace_id])
  @@index([message_id])
  @@index([thread_id])
  @@map("mcp_decisions")
}

model EmailMessage {
  id               String   @id @default(uuid()) @db.Uuid

  workspace_id     String   @db.Uuid

  gmail_message_id String   @unique @db.VarChar(255)
  thread_id        String   @db.VarChar(255)

  sender           String   @db.VarChar(255)
  recipient        String?  @db.VarChar(255)

  subject          String?  @db.Text
  body             String   @db.Text

  direction        String   @db.VarChar(20) // inbound / outbound

  is_processed     Boolean  @default(false)

  created_at       DateTime @db.Timestamptz(6)
  stored_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([workspace_id])
  @@index([thread_id])
  @@index([sender])
  @@map("emails")
}

model CalendarEvent {
  id             String   @id @default(uuid()) @db.Uuid
  workspace_id   String   @db.Uuid

  title          String?
  description    String?

  event_date     DateTime
  event_time     String
  timezone       String?
  location       String?

  google_event_id String?
  sync_status     String   @default("pending")

  status         String   @default("scheduled")

  created_at     DateTime @default(now())

  @@index([workspace_id])
  @@map("calendar_events")
}

model EmailReplyLog {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String   @db.Uuid

  thread_id    String?
  message_id   String?

  reply_text   String   @db.Text

  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@index([thread_id])
  @@map("email_reply_logs")
}

model Integration {
  id                  String   @id @default(uuid()) @db.Uuid
  workspace_id        String   @db.Uuid

  integration_type    String   @db.VarChar(50)

  access_token        String?  @db.Text
  refresh_token       String?  @db.Text
  token_expiry        DateTime?

  connected_email     String?  @db.VarChar(255)
  connected_account_id String? @db.VarChar(255)

  is_active           Boolean  @default(true)

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([workspace_id])
  @@map("integrations")
}