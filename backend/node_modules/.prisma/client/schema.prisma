generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  full_name       String
  created_at      DateTime          @default(now())
  
  // Relations
  workspace_members WorkspaceMember[]
  learning_events   LearningEvent[]
  followups         Followup[]
  conversations     Conversation[]
  promises          Promise[]

  @@map("users")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  created_at  DateTime @default(now())

  // Relations
  members         WorkspaceMember[]
  learning_events LearningEvent[]
  followups       Followup[]
  ai_actions      AIAction[]
  brain_entries   Brain[]
  conversations   Conversation[]
  promises        Promise[]

  @@map("workspaces")
}

model WorkspaceMember {
  id           String   @id @default(uuid())
  user_id      String
  workspace_id String
  role         String
  joined_at    DateTime @default(now())

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("workspace_members")
}

model LearningEvent {
  id               String   @id @default(uuid())
  workspace_id     String
  user_id          String?
  event_type       String
  context          String?  @db.Text
  outcome          String?
  confidence_score Float?
  created_at       DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [user_id], references: [id])

  @@map("learning_events")
}

model Followup {
  id           String    @id @default(uuid())
  workspace_id String
  user_id      String?
  title        String
  description  String?   @db.Text
  status       String    @default("pending")
  due_date     DateTime?
  created_at   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [user_id], references: [id])

  @@map("followups")
}

model AIAction {
  id           String   @id @default(uuid())
  workspace_id String
  action_type  String
  description  String?  @db.Text
  decision     String?
  approved     Boolean?
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("ai_actions")
}

model Brain {
  id           String   @id @default(uuid())
  workspace_id String
  title        String
  content      String   @db.Text
  source_type  String?
  source_url   String?  @db.Text
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("brain")
}

model Conversation {
  id           String   @id @default(uuid())
  workspace_id String
  user_id      String?
  title        String?
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [user_id], references: [id])
  messages  Message[]

  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  conversation_id String
  role            String
  content         String   @db.Text
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Promise {
  id           String   @id @default(uuid())
  workspace_id String
  user_id      String?
  promise_text String   @db.Text
  status       String   @default("pending")
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [user_id], references: [id])

  @@map("promises")
}
